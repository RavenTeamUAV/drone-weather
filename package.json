{
  "name": "drone-weather",
  "version": "1.0.0",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:win": "pkg . --targets node18-win-x64     --output dist/drone-weather-windows.exe",
    "build:mac": "pkg . --targets node18-macos-x64   --output dist/drone-weather-macos-intel",
    "build:mac-arm": "pkg . --targets node18-macos-arm64 --output dist/drone-weather-macos-arm",
    "build:linux": "pkg . --targets node18-linux-x64   --output dist/drone-weather-linux",
    "build": "npm run build:win && npm run build:mac && npm run build:mac-arm && npm run build:linux"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "data/**/*"
    ],
    "targets": [
      "node18-win-x64",
      "node18-macos-x64",
      "node18-macos-arm64",
      "node18-linux-x64"
    ],
    "outputPath": "dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.12.0"
  }
}
