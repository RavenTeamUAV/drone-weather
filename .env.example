# Порт сервера (за замовчуванням 3000)
PORT=3000

# Ключ Windy API для шару вітру на карті (необов'язково)
# Отримати безкоштовно: https://api.windy.com/map-player
WINDY_API_KEY=your_windy_api_key_here

# Макс. кількість точок маршруту (за замовчуванням 150)
# MAX_WAYPOINTS=150

# Макс. розмір файлу місії в байтах (за замовчуванням 500 КБ)
# MAX_MISSION_FILE_SIZE=512000

# TTL кешу погоди в хвилинах (за замовчуванням 5)
# CACHE_TTL_MINUTES=5

# Rate limit: макс. запитів на IP за 15 хв (за замовчуванням 120)
# RATE_LIMIT_MAX=120
